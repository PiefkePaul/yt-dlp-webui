# Server
PORT=3000
TMP_DIR=./tmp
JOB_TTL_MS=1800000

# Runtime dependencies
YTDLP_COOKIES_FILE=

# Frontend / cross-origin access
PUBLIC_API_BASE_URL=
CORS_ALLOWED_ORIGINS=
PUBLIC_DEMO_MODE=false
PUBLIC_DEMO_MESSAGE=

# FFmpeg / MP4 encoding
FFMPEG_HWACCEL=auto
FFMPEG_MP4_HW_ENCODER=h264_qsv
FFMPEG_QSV_PRESET=medium
FFMPEG_QSV_GLOBAL_QUALITY=23
FFMPEG_X264_PRESET=medium
FFMPEG_X264_CRF=23
FFMPEG_AAC_BITRATE=192

# SoundCloud Auth API — Web-Client-ID (Fallback; yt-dlp Standard)
# Überschreiben wenn SC diese ID sperrt
SC_CLIENT_ID=i53MAi5VcJrq7u38ZL1SOZtDi17ds1A0

# AES-256-GCM Key für Client-seitige Credential-Verschlüsselung (Pflicht)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=
