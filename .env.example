# Server
PORT=3000
TMP_DIR=./tmp
JOB_TTL_MS=1800000
MAX_CONCURRENT_JOBS=1
INSPECT_ENTRY_LIMIT=12

# Runtime dependencies
# Optional global fallback cookie file. Per-session cookies can also be pasted in the UI.
YTDLP_COOKIES_FILE=

# Frontend / cross-origin access
PUBLIC_API_BASE_URL=
CORS_ALLOWED_ORIGINS=
PUBLIC_DEMO_MODE=false
PUBLIC_DEMO_MESSAGE=

# FFmpeg / MP4 encoding
FFMPEG_HWACCEL=auto
FFMPEG_MP4_HW_ENCODER=h264_qsv
FFMPEG_QSV_PRESET=medium
FFMPEG_QSV_GLOBAL_QUALITY=23
FFMPEG_X264_PRESET=medium
FFMPEG_X264_CRF=23
FFMPEG_AAC_BITRATE=192
